MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/poultrymanager
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRE=30d
FRONTEND_URL=http://localhost:5173
PORT=5001
NODE_ENV=development

# Hetzner S3 Object Storage
HETZNER_S3_BUCKET=your-bucket-name
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_REGION=fsn1
HETZNER_S3_ACCESS_KEY=your-access-key
HETZNER_S3_SECRET_KEY=your-secret-key
